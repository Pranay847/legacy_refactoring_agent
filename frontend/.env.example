# ============================================================================
# Frontend environment (frontend/.env)  —  copy to ".env" and fill in.
# ----------------------------------------------------------------------------
# Vite only exposes variables prefixed with VITE_ to the browser bundle, so
# ONLY browser-safe, publishable values belong here. NEVER put a secret key
# (Stripe secret, Supabase service-role, Clerk secret) in this file.
# ============================================================================

# Base URL of the backend API (include the /api suffix).
# Defaults to http://127.0.0.1:8000/api when unset.
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# --- Phase 2: Clerk (publishable key only) ----------------------------------
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# --- Phase 1: Supabase client (anon key only) -------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...
