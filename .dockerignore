# --- VCS / Python caches ---
.git
.gitignore
.venv
venv
env
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.mypy_cache
*.log

# --- Frontend (built as its own image, see frontend/Dockerfile) ---
frontend

