# Terraform working files — never commit these.
.terraform/
.terraform.tfstate.lock.info
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Secrets / per-user input. Keep the .example, ignore the real one.
*.tfvars
*.tfvars.json
!*.tfvars.example

override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
