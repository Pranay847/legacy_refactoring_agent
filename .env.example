# ============================================================================
# Backend environment (repo-root .env)  —  copy to ".env" and fill in.
# ----------------------------------------------------------------------------
# EVERY value in this file is SERVER-SIDE ONLY. Never put these in the frontend
# or commit a real .env (it is gitignored). Browser-safe keys live in
# frontend/.env.example instead.
# ============================================================================

# --- Runtime ----------------------------------------------------------------
ENVIRONMENT=development          # development | production
DEBUG=true                       # false in production

# --- AI generation (Anthropic Claude) ---------------------------------------
# ANTHROPIC_API_KEY is preferred; API_KEY is still accepted as an alias.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Generation provider ----------------------------------------------------
# "anthropic" (default, paid API) or "ollama" (local model, free). With ollama
# the Anthropic model choice is ignored and OLLAMA_MODEL is used instead.
LLM_PROVIDER=anthropic
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# --- Graph database (Neo4j) -------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# --- Generation concurrency -------------------------------------------------
GENERATION_WORKERS=5
GENERATION_MAX_WORKERS=10

# --- CORS / frontend --------------------------------------------------------
# Public URL of the deployed frontend (added to the CORS allow-list).
FRONTEND_URL=https://your-frontend.example.com

# ============================================================================
# Phase 1 — Supabase (Postgres + storage + RLS)
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS: keep it strictly server-side.
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ============================================================================
# Phase 2 — Clerk authentication
# Backend verifies Clerk-issued JWTs. JWKS_URL/ISSUER come from the Clerk
# dashboard (API Keys -> Show JWT public key / Frontend API URL).
# ============================================================================
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_JWKS_URL=https://your-clerk-subdomain.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-subdomain.clerk.accounts.dev

# ============================================================================
# Phase 3 — Stripe subscription tiers (Free / Pro / Team)
# Price IDs come from Stripe Dashboard -> Products. Webhook secret comes from
# the webhook endpoint you create (whsec_...).
# ============================================================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_TEAM=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PORTAL_RETURN_URL=https://your-frontend.example.com/billing

# ============================================================================
# Phases 4-5 — Redis (rate limiting, caching, async job queue)
# Use a managed Redis (Upstash, Railway, Render) in production.
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# Rate limiting turns on automatically when REDIS_URL is set (shared across
# workers). Set this to true to force the per-process in-memory fallback on a
# single-instance host that has no Redis.
RATE_LIMIT_ENABLED=false
